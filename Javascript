// server.js
const http = require('http');
const fs = require('fs');
const path = require('path');
const crypto = require('crypto');
const { URL } = require('url');

const PORT = process.env.PORT || 3000;
const BASE_DIR = __dirname;
const DATA_DIR = path.join(BASE_DIR, 'data');
const USERS_FILE = path.join(DATA_DIR, 'users.json');
const MENUS_FILE = path.join(DATA_DIR, 'menus.json');
const SESSIONS_FILE = path.join(DATA_DIR, 'sessions.json');
const PUBLIC_DIR = path.join(BASE_DIR, 'public');
const SESSION_COOKIE = 'dzgnburger_sid';
const USD_RATE = 38.5;

const ROLE_CONFIG = {
  admin: { redirectTo: '/admin', label: 'Admin' },
  caretaker: { redirectTo: '/caretaker', label: 'Caretaker' },
  user: { redirectTo: '/home', label: 'User' }
};

function ensureDataFiles() {
  if (!fs.existsSync(DATA_DIR)) fs.mkdirSync(DATA_DIR, { recursive: true });
  if (!fs.existsSync(USERS_FILE)) writeJson(USERS_FILE, []);
  if (!fs.existsSync(MENUS_FILE)) writeJson(MENUS_FILE, []);
  if (!fs.existsSync(SESSIONS_FILE)) writeJson(SESSIONS_FILE, {});
  seedInitialData();
}

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, 'utf8'));
}

function writeJson(filePath, value) {
  fs.writeFileSync(filePath, JSON.stringify(value, null, 2), 'utf8');
}

function nowIso() {
  return new Date().toISOString();
}

function nextId(items) {
  if (!items.length) return 1;
  return Math.max(...items.map(item => item.id)) + 1;
}

function toUsd(tl) {
  return Number((Number(tl) / USD_RATE).toFixed(2));
}

function hashPassword(password, salt = crypto.randomBytes(16).toString('hex')) {
  const derived = crypto.scryptSync(password, salt, 64).toString('hex');
  return `${salt}:${derived}`;
}

function verifyPassword(password, storedValue) {
  const [salt, originalHash] = storedValue.split(':');
  const currentHash = crypto.scryptSync(password, salt, 64).toString('hex');
  return crypto.timingSafeEqual(Buffer.from(originalHash, 'hex'), Buffer.from(currentHash, 'hex'));
}

