function requireAuth(req, res) {
  const session = getSession(req);
  if (!session) {
    redirect(res, '/login');
    return null;
  }
  return session.data;
}

function requireRole(req, res, allowedRoles) {
  const user = requireAuth(req, res);
  if (!user) return null;
  if (!allowedRoles.includes(user.role)) {
    redirect(res, '/dashboard');
    return null;
  }
  return user;
}

async function handleRoute(req, res) {
  const parsedUrl = new URL(req.url, `http://${req.headers.host}`);
  const pathname = parsedUrl.pathname;
  const session = getSession(req);
  const user = session ? session.data : null;

  if (pathname.startsWith('/public/')) {
    return sendFile(res, path.join(PUBLIC_DIR, pathname.replace('/public/', '')));
  }

  if (req.method === 'GET' && pathname === '/') {
    return sendHtml(res, layout({ title: 'DZGNburger', user, content: renderPublicMenu() }));
  }

  if (req.method === 'GET' && pathname === '/register') {
    if (user) return redirect(res, '/dashboard');
    return sendHtml(res, layout({ title: 'Register', user, content: renderAuthPage('register') }));
  }

  if (req.method === 'POST' && pathname === '/register') {
    if (user) return redirect(res, '/dashboard');
    const form = await parseBody(req);
    const { fullName, email, password, confirmPassword, role } = form;
    const safeRole = ROLE_CONFIG[role] ? role : 'user';
    const users = readJson(USERS_FILE);

    if (!fullName || !email || !password || !confirmPassword) {
      return sendHtml(res, layout({ title: 'Register', user: null, content: renderAuthPage('register', form, 'All fields are required.') }), 400);
    }
    if (password.length < 6) {
      return sendHtml(res, layout({ title: 'Register', user: null, content: renderAuthPage('register', form, 'Password must be at least 6 characters.') }), 400);
    }
    if (password !== confirmPassword) {
      return sendHtml(res, layout({ title: 'Register', user: null, content: renderAuthPage('register', form, 'Passwords do not match.') }), 400);
    }
    if (users.find(u => u.email === email.toLowerCase())) {
      return sendHtml(res, layout({ title: 'Register', user: null, content: renderAuthPage('register', form, 'This email is already registered.') }), 400);
    }

    const newUser = createUserRecord(fullName, email, password, safeRole);
    users.push(newUser);
    writeJson(USERS_FILE, users);
    const sessionId = createSession(newUser);
    return redirect(res, ROLE_CONFIG[newUser.role].redirectTo, `${SESSION_COOKIE}=${sessionId}; HttpOnly; Path=/; Max-Age=7200`);
  }

  if (req.method === 'GET' && pathname === '/login') {
    if (user) return redirect(res, '/dashboard');
    return sendHtml(res, layout({ title: 'Login', user, content: renderAuthPage('login') }));
  }

  if (req.method === 'POST' && pathname === '/login') {
    if (user) return redirect(res, '/dashboard');
    const form = await parseBody(req);
    const { email, password } = form;
    const users = readJson(USERS_FILE);
    const found = users.find(u => u.email === String(email || '').toLowerCase());

    if (!email || !password) {
      return sendHtml(res, layout({ title: 'Login', user: null, content: renderAuthPage('login', form, 'Email and password are required.') }), 400);
    }
    if (!found || !verifyPassword(password, found.passwordHash)) {
      return sendHtml(res, layout({ title: 'Login', user: null, content: renderAuthPage('login', form, 'Invalid email or password.') }), 401);
    }

    const sessionId = createSession(found);
    return redirect(res, ROLE_CONFIG[found.role].redirectTo, `${SESSION_COOKIE}=${sessionId}; HttpOnly; Path=/; Max-Age=7200`);
  }

  if (req.method === 'POST' && pathname === '/logout') {
    if (session) destroySession(session.id);
    return redirect(res, '/login', `${SESSION_COOKIE}=; HttpOnly; Path=/; Max-Age=0`);
  }

  if (req.method === 'GET' && pathname === '/dashboard') {
    const protectedUser = requireAuth(req, res);
    if (!protectedUser) return;
    return redirect(res, ROLE_CONFIG[protectedUser.role].redirectTo);
  }

  if (req.method === 'GET' && pathname === '/home') {
    const protectedUser = requireRole(req, res, ['user', 'caretaker', 'admin']);
    if (!protectedUser) return;
    return sendHtml(res, layout({ title: 'User Home', user: protectedUser, content: renderUserHome(protectedUser) }));
  }

  if (req.method === 'GET' && pathname === '/caretaker') {
    const protectedUser = requireRole(req, res, ['caretaker', 'admin']);
    if (!protectedUser) return;
    return sendHtml(res, layout({ title: 'Caretaker', user: protectedUser, content: renderCaretakerPage() }));
  }

  if (req.method === 'POST' && pathname === '/caretaker/menu-items') {
    const protectedUser = requireRole(req, res, ['caretaker', 'admin']);
    if (!protectedUser) return;
    const form = await parseBody(req);
    const price = Number(form.priceTl);

    if (!form.name || !form.category || !form.description || Number.isNaN(price) || price <= 0) {
      return sendHtml(res, layout({ title: 'Caretaker', user: protectedUser, content: renderCaretakerPage(form, 'Please enter a valid name, category, description, and positive price.') }), 400);
    }

    const menus = readJson(MENUS_FILE);
    menus.push({
      id: nextId(menus),
      name: form.name,
      category: form.category,
      description: form.description,
      priceTl: Number(price.toFixed(2)),
      priceUsd: toUsd(price),
      createdBy: protectedUser.userId,
      caretakerName: protectedUser.fullName,
      createdAt: nowIso()
    });
    writeJson(MENUS_FILE, menus);

    return sendHtml(res, layout({ title: 'Caretaker', user: protectedUser, content: renderCaretakerPage({}, '', 'Menu item created successfully.') }));
  }

  if (req.method === 'GET' && pathname === '/admin') {
    const protectedUser = requireRole(req, res, ['admin']);
    if (!protectedUser) return;
    return sendHtml(res, layout({ title: 'Admin', user: protectedUser, content: renderAdminPage() }));
  }

  return sendHtml(res, layout({ title: 'Not Found', user, content: '<section class="section-block"><h1>404</h1><p>Page not found.</p></section>' }), 404);
}

ensureDataFiles();

const server = http.createServer((req, res) => {
  handleRoute(req, res).catch(error => {
    console.error(error);
    sendHtml(res, layout({ title: 'Error', user: null, content: `<section class="section-block"><h1>Server Error</h1><p>${escapeHtml(error.message)}</p></section>` }), 500);
  });
});

server.listen(PORT, () => {
  console.log(`DZGNburger running at http://localhost:${PORT}`);
});
