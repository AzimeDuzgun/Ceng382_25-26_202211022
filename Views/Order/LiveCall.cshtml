@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Canlı Çağrı - DZGN Catering</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
            body {
                background-color: #0a0f16;
                color: white;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                overflow: hidden;
            }

            .pulse-avatar {
                width: 150px;
                height: 150px;
                border-radius: 50%;
                background: linear-gradient(135deg, #D4AF37, #e5c158);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 4rem;
                color: #0a0f16;
                box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7);
                animation: pulseEffect 1.8s infinite;
                margin: 0 auto 2rem auto;
            }

            /* RAZOR ÇAKIŞMASI BURADA ÇİFT @@ İLE ÇÖZÜLDÜ */
            @@keyframes pulseEffect {
                0% {
                    transform: scale(0.95);
                    box-shadow: 0 0 0 0 rgba(212, 175, 55, 0.7);
                }

                70% {
                    transform: scale(1);
                    box-shadow: 0 0 0 35px rgba(212, 175, 55, 0);
                }

                100% {
                    transform: scale(0.95);
                    box-shadow: 0 0 0 0 rgba(212, 175, 55, 0);
                }
            }

            .call-buttons button, .call-buttons a {
                width: 70px;
                height: 70px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                transition: transform 0.2s;
            }

                .call-buttons button:hover, .call-buttons a:hover {
                    transform: scale(1.1);
                }
    </style>
</head>
<body class="text-center">
    <div>
        <div class="pulse-avatar">
            <i class="fa-solid fa-store"></i>
        </div>

        <h2 class="fw-bold mb-1">Restoran Yetkilisi</h2>
        <p class="text-white-50 mb-5 fs-5">Güvenli hat üzerinden bağlanılıyor... <span id="timer" class="text-warning fw-bold ms-2">00:00</span></p>

        <div class="d-flex justify-content-center gap-4 call-buttons">
            <button class="btn btn-secondary rounded-circle border-0 bg-opacity-25"><i class="fa-solid fa-microphone-slash"></i></button>
            <a href="javascript:history.back()" class="btn btn-danger rounded-circle shadow-lg text-white">
                <i class="fa-solid fa-phone-slash"></i>
            </a>
            <button class="btn btn-secondary rounded-circle border-0 bg-opacity-25"><i class="fa-solid fa-volume-high"></i></button>
        </div>
    </div>

    <script>
            let sec = 0;
            setInterval(() => {
                sec++;
                let m = Math.floor(sec / 60).toString().padStart(2, '0');
                let s = (sec % 60).toString().padStart(2, '0');
                document.getElementById('timer').innerText = m + ':' + s;
            }, 1000);
    </script>
</body>
</html>