@model DZGNCatering.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg rounded-3" style="background-color: #ffffff;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color: var(--primary-color);">DZGN Catering</h2>
                    <p class="text-muted">Hemen kaydolun, lezzete ortak olun.</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label small fw-bold">Ad Soyad</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                            <input asp-for="FullName" class="form-control bg-light border-start-0" placeholder="John Doe" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold">E-posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control bg-light border-start-0" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label small fw-bold">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                            <input asp-for="Password" class="form-control bg-light border-start-0" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label small fw-bold">Şifre Tekrar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control bg-light border-start-0" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="District" class="form-label small fw-bold">Bulunduğunuz İlçe (Hizmet Bölgesi)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-location-dot text-muted"></i></span>
                            <select asp-for="District" class="form-select bg-light border-start-0" required>
                                <option value="">Lütfen İlçe Seçin...</option>
                                <option value="Çankaya">Ankara - Çankaya</option>
                                <option value="Keçiören">Ankara - Keçiören</option>
                                <option value="Yenimahalle">Ankara - Yenimahalle</option>
                                <option value="Mamak">Ankara - Mamak</option>
                                <option value="Etimesgut">Ankara - Etimesgut</option>
                                <option value="Gölbaşı">Ankara - Gölbaşı</option>
                            </select>
                        </div>
                        <span asp-validation-for="District" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Role" class="form-label small fw-bold">Hesap Türü</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-users-gear text-muted"></i></span>
                            <select asp-for="Role" class="form-select bg-light border-start-0">
                                <option value="User">Müşteri (Yemek Siparişi Vereceğim)</option>
                                <option value="Caretaker">Yemek Firması / Restoran (Menü Satacağım)</option>
                            </select>
                        </div>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-2 rounded-pill shadow-sm mb-3">Hesap Oluştur</button>
                </form>

                <div class="text-center mt-3">
                    <span class="small text-muted">Zaten hesabınız var mı? </span>
                    <a asp-action="Login" style="color: var(--primary-color);" class="small fw-bold text-decoration-none">Giriş Yapın</a>
                </div>
            </div>
        </div>
    </div>
</div>