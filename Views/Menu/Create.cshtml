@model DZGNCatering.Models.Menu
@{
    ViewData["Title"] = "Yeni Menü Oluştur";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-3">
            <div class="card-body p-5">
                <h3 class="fw-bold mb-4" style="color: var(--primary-color);"><i class="fa-solid fa-folder-plus"></i> Yeni Menü Oluştur</h3>

                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label small fw-bold">Menü Adı</label>
                        <input asp-for="Name" class="form-control bg-light" placeholder="Örn: Akdeniz Lezzetleri Menüsü" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label small fw-bold">Menü İçeriği / Açıklama</label>
                        <textarea asp-for="Description" class="form-control bg-light" rows="3" placeholder="Menü içeriğini yazınız..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CustomizationDefinitions" class="form-label small fw-bold">Özelleştirme Seçenekleri (Virgülle Ayırın)</label>
                        <input asp-for="CustomizationDefinitions" class="form-control bg-light" placeholder="Örn: Acı Seçeneği, Porsiyon Büyütme, Sos Seçimi" />
                        <span asp-validation-for="CustomizationDefinitions" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label small fw-bold">Menü Fiyatı (TL)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">₺</span>
                            <input asp-for="Price" type="number" step="0.01" class="form-control bg-light" placeholder="250.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold">Menü Görseli (Fotoğraf)</label>
                        <input type="file" name="imageFile" class="form-control bg-light" accept="image/*" />
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-light w-50 py-2 rounded-pill fw-bold">İptal Et</a>
                        <button type="submit" class="btn btn-gold w-50 py-2 rounded-pill shadow-sm fw-bold">Menüyü Yayınla</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>