@model DZGNCatering.Models.Menu
@{
    ViewData["Title"] = "Menü Güncelle";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-3">
            <div class="card-body p-5">
                <div class="border-start border-4 border-warning ps-3 mb-4">
                    <h3 class="fw-bold m-0" style="color: var(--primary-color);"><i class="fa-solid fa-utensils"></i> Menüyü Güncelle</h3>
                    <small class="text-muted">Yemek detaylarını, fiyatını veya görselini revize edin</small>
                </div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CaretakerId" />
                    <input type="hidden" asp-for="ImageUrl" /> <div class="mb-3">
                    <label asp-for="Name" class="form-label small fw-bold">Yemek / Menü Adı</label>
                    <input asp-for="Name" class="form-control bg-light" placeholder="Örn: Kıymalı Mercimek Menü" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label small fw-bold">Menü İçeriği ve Detaylar</label>
                    <textarea asp-for="Description" class="form-control bg-light" rows="3" placeholder="Yemeğin yanında verilecek garnitürler, içecekler vb..." required></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label small fw-bold">Porsiyon Fiyatı (₺)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light">₺</span>
                        <input asp-for="Price" type="number" step="0.01" class="form-control bg-light" placeholder="0.00" required />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold d-block">Menü Görseli</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-2">
                            <small class="text-muted d-block mb-1">Mevcut Resim:</small>
                            <img src="@Model.ImageUrl" class="rounded border shadow-sm" style="width: 120px; height: 90px; object-fit: cover;" />
                        </div>
                    }
                    <input type="file" name="ImageFile" class="form-control bg-light" accept="image/*" />
                    <small class="text-muted-50" style="font-size: 0.75rem;">Değiştirmek istemiyorsanız boş bırakın.</small>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a asp-action="MyMenus" class="btn btn-light w-50 py-2 rounded-pill fw-bold">İptal Et</a>
                    <button type="submit" class="btn btn-gold w-50 py-2 rounded-pill shadow-sm fw-bold">
                        <i class="fa-solid fa-floppy-disk"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</div>